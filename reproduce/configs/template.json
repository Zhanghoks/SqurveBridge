{
  "api_key": {
    "<provider>": "your_api_key_here"
  },
  "llm": {
    "use": "<provider>",
    "model_name": "<model_name>",
    "context_window": 120000,
    "max_token": 8000,
    "top_p": 0.9,
    "temperature": 0,
    "time_out": 300.0
  },
  "text_embed": {
    "embed_model_name": "<embed_model_name>"
  },
  "dataset": {
    "data_source": "<benchmark>:<split>:",
    "data_source_dir": "../files/data_source",
    "need_few_shot": false,
    "need_external": false
  },
  "database": {
    "skip_schema_init": false,
    "schema_source": "<benchmark>:<split>",
    "multi_database": false,
    "vector_store": "../vector_store",
    "schema_source_dir": "../files/schema_source",
    "need_build_index": false
  },
  "task": {
    "task_meta": [
      {
        "task_id": "generate",
        "task_type": "GenerateTask",
        "data_source": "<benchmark>:<split>:",
        "schema_source": "<benchmark>:<split>",
        "dataset_save_path": "../files/datasets/<dataset>_<method>.json",
        "is_save_dataset": true,
        "eval_type": [
          "execute_accuracy"
        ],
        "meta": {
          "task": {
            "generate_type": "<GeneratorClass>"
          },
          "actor": {
            "save_dir": "../files/pred_sql/<dataset>_<method>"
          }
        },
        "open_parallel": true,
        "max_workers": 2
      }
    ]
  },
  "dataset_save_dir": "../files/datasets/",
  "sql_save_dir": "../files/pred_sql/",
  "generate_num": 1,
  "checkpoint": {
    "enabled": true,
    "interval": 50,
    "save_state": true
  },
  "engine": {
    "exec_process": [
      "generate"
    ]
  }
}
