{
  "api_key": {
    "qwen": "${ENV:QWEN_API_KEY}"
  },
  "llm": {
    "use": "qwen",
    "model_name": "qwen-turbo",
    "context_window": 120000,
    "max_token": 8000,
    "top_p": 0.9,
    "temperature": 0.0,
    "time_out": 300.0
  },
  "text_embed": {
    "embed_model_name": "BAAI/bge-large-en-v1.5"
  },
  "dataset": {
    "data_source": "BookSQL:val:",
    "data_source_dir": "../files/data_source",
    "need_few_shot": false,
    "need_external": false
  },
  "database": {
    "skip_schema_init": false,
    "schema_source": "BookSQL:val",
    "multi_database": false,
    "vector_store": "../vector_store",
    "schema_source_dir": "../files/schema_source",
    "need_build_index": false
  },
  "task": {
    "task_meta": [
      {
        "task_id": "resdsql_reduce",
        "task_type": "ReduceTask",
        "data_source": "BookSQL:val:",
        "schema_source": "BookSQL:val",
        "dataset_save_path": "../files/datasets/booksql_resdsql_resdsql_reduce.json",
        "is_save_dataset": true,
        "eval_type": [
          "reduce_recall",
          "reduce_precision",
          "reduce_rate"
        ],
        "meta": {
          "task": {
            "reduce_type": "RESDSQLBooksqlReducer"
          },
          "actor": {
            "save_dir": "../files/instance_schemas/booksql_resdsql"
          }
        },
        "open_parallel": true,
        "max_workers": 8
      },
      {
        "task_id": "resdsql_generate",
        "task_type": "GenerateTask",
        "data_source": "BookSQL:val:",
        "schema_source": "BookSQL:val",
        "dataset_save_path": "../files/datasets/booksql_resdsql_resdsql_generate.json",
        "is_save_dataset": true,
        "eval_type": [
          "execute_accuracy"
        ],
        "meta": {
          "task": {
            "generate_type": "RESDSQLBooksqlGenerator"
          },
          "actor": {
            "save_dir": "../files/pred_sql/booksql_resdsql",
            "n_candidates": 4
          }
        },
        "open_parallel": true,
        "max_workers": 8
      }
    ],
    "cpx_task_meta": [
      {
        "task_id": "resdsql_full",
        "task_lis": [
          "resdsql_reduce",
          "resdsql_generate"
        ],
        "eval_type": [
          "execute_accuracy"
        ],
        "dataset_save_path": "../files/datasets/booksql_resdsql_full.json",
        "is_save_dataset": true,
        "open_parallel": true,
        "max_workers": 8
      }
    ]
  },
  "dataset_save_dir": "../files/datasets/",
  "sql_save_dir": "../files/pred_sql/",
  "generate_num": 1,
  "checkpoint": {
    "enabled": true,
    "interval": 50,
    "save_state": true
  },
  "engine": {
    "exec_process": [
      "resdsql_full"
    ]
  }
}
