{
  "api_key": {
    "qwen": "${ENV:QWEN_API_KEY}"
  },
  "llm": {
    "use": "qwen",
    "model_name": "deepseek-v4-flash",
    "context_window": 128000,
    "max_token": 2048,
    "top_p": 1.0,
    "temperature": 0.0,
    "time_out": 300.0
  },
  "text_embed": {
    "embed_model_name": "BAAI/bge-large-en-v1.5"
  },
  "dataset": {
    "data_source": "bird:dev:",
    "data_source_dir": "../files/data_source",
    "db_path": "../benchmarks/bird/dev/database",
    "need_few_shot": false,
    "need_external": false
  },
  "database": {
    "skip_schema_init": false,
    "schema_source": "bird:dev",
    "multi_database": false,
    "vector_store": "../vector_store",
    "schema_source_dir": "../files/schema_source",
    "need_build_index": false
  },
  "task": {
    "task_meta": [
      {
        "task_id": "generate",
        "task_type": "GenerateTask",
        "data_source": "bird:dev:",
        "schema_source": "bird:dev",
        "dataset_save_path": "../files/datasets/bird_esql_smoke.json",
        "is_save_dataset": true,
        "eval_type": ["execute_accuracy"],
        "meta": {
          "task": {
            "generate_type": "ESQLGenerator"
          },
          "actor": {
            "save_dir": "../files/pred_sql/bird_esql_smoke",
            "bird_root": "../benchmarks/bird/dev",
            "enrichment_level": "complex",
            "enrichment_level_shot_number": 3,
            "generation_level_shot_number": 3,
            "db_sample_limit": 5,
            "relevant_description_number": 6,
            "seed": 42
          }
        },
        "open_parallel": true,
        "max_workers": 8
      }
    ]
  },
  "dataset_save_dir": "../files/datasets/",
  "sql_save_dir": "../files/pred_sql/",
  "generate_num": 1,
  "checkpoint": {
    "enabled": true,
    "interval": 5,
    "save_state": true
  },
  "engine": {
    "exec_process": ["generate"]
  }
}
