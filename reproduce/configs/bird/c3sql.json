{
  "api_key": {
    "deepseek": "your_api_key_here",
    "qwen": "${ENV:QWEN_API_KEY}",
    "zhipu": "your_api_key_here"
  },
  "llm": {
    "use": "qwen",
    "model_name": "deepseek-v4-flash",
    "context_window": 64000,
    "max_token": 8000,
    "top_p": 0.8,
    "temperature": 0.7,
    "time_out": 300.0
  },
  "text_embed": {
    "embed_model_name": "BAAI/bge-large-en-v1.5"
  },
  "dataset": {
    "data_source": "bird:dev:",
    "data_source_dir": "../files/data_source",
    "need_few_shot": false,
    "need_external": false
  },
  "database": {
    "skip_schema_init": false,
    "schema_source": "bird:dev",
    "multi_database": false,
    "vector_store": "../vector_store",
    "schema_source_dir": "../files/schema_source",
    "need_build_index": false
  },
  "task": {
    "task_meta": [
      {
        "task_id": "generate",
        "task_type": "GenerateTask",
        "data_source": "bird:dev:",
        "schema_source": "bird:dev",
        "dataset_save_path": "../files/datasets/bird_c3sql.json",
        "is_save_dataset": true,
        "eval_type": ["execute_accuracy"],
        "meta": {
          "task": { "generate_type": "C3SQLGenerator" },
          "actor": { "save_dir": "../files/pred_sql/bird_c3sql", "n_candidates": 20 }
        },
        "open_parallel": true,
        "max_workers": 16
      },
      {
        "task_id": "c3sql_reduce",
        "task_type": "ReduceTask",
        "data_source": "bird:dev:",
        "schema_source": "bird:dev",
        "dataset_save_path": "../files/datasets/bird_c3sql_reduce.json",
        "is_save_dataset": true,
        "eval_type": ["reduce_recall", "reduce_precision", "reduce_rate"],
        "meta": {
          "task": { "reduce_type": "C3SQLReducer" },
          "actor": { "sc_num": 10, "top_k": 6, "add_fk_neighbors": true }
        },
        "open_parallel": true,
        "max_workers": 16
      },
      {
        "task_id": "c3sql_parse",
        "task_type": "ParseTask",
        "data_source": "bird:dev:",
        "schema_source": "bird:dev",
        "dataset_save_path": "../files/datasets/bird_c3sql_parse.json",
        "is_save_dataset": true,
        "eval_type": ["parse_recall", "parse_precision", "parse_exact_matching"],
        "meta": {
          "task": { "parse_type": "C3SQLParser" },
          "actor": { "sc_num": 10, "top_k": 5, "add_fk": true, "output_format": "list" }
        },
        "open_parallel": true,
        "max_workers": 16
      }
    ],
    "cpx_task_meta": [
      {
        "task_id": "c3sql_full",
        "task_name": "C3SQL Three-Stage Pipeline",
        "task_lis": ["c3sql_reduce", "c3sql_parse", "generate"],
        "eval_type": ["execute_accuracy"],
        "dataset_save_path": "../files/datasets/bird_c3sql_full.json",
        "is_save_dataset": true,
        "open_parallel": true,
        "max_workers": 16,
        "pipeline_run_mode": "sample"
      }
    ]
  },
  "dataset_save_dir": "../files/datasets/",
  "sql_save_dir": "../files/pred_sql/",
  "generate_num": 1,
  "checkpoint": {
    "enabled": true,
    "interval": 50,
    "save_state": true
  },
  "engine": {
    "exec_process": ["c3sql_full"]
  }
}
