# Copy to package root as `.env` (git-ignored).
# Used by `reproduce/run.py` and the live demo API.
# Keys map to reproduce config `api_key.<provider>` when the config value is
# a placeholder or `${ENV:VAR_NAME}`.

# Default provider for bundled Spider/BIRD configs
QWEN_API_KEY=your_qwen_api_key_here

# Embedded Pi Agent backend. Defaults to SQURVE_LLM_PROVIDER/SQURVE_LLM_MODEL
# when these values are omitted.
PI_AGENT_PROVIDER=qwen
PI_AGENT_MODEL=qwen-plus

# Optional additional providers
ZHIPU_API_KEY=your_zhipu_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
