{
  "api_key": {
    "<provider>": "${ENV:<PROVIDER>_API_KEY}"
  },
  "llm": {
    "use": "<provider>",
    "model_name": "<model>",
    "context_window": 8192,
    "temperature": 0,
    "time_out": 60
  },
  "dataset": {
    "data_source": "<benchmark>:<split>:",
    "need_few_shot": false,
    "need_external": false
  },
  "database": {
    "schema_source": "<benchmark>:<split>:",
    "need_build_index": false
  },
  "task": {
    "task_meta": [
      {
        "task_id": "<slug>_reduce",
        "task_type": "ReduceTask",
        "dataset_save_path": "../files/datasets/<slug>_reduce.json",
        "is_save_dataset": true,
        "eval_type": ["reduce_recall", "reduce_precision", "reduce_rate"],
        "meta": {
          "task": {
            "reduce_type": "<ReducerClass>"
          }
        }
      },
      {
        "task_id": "<slug>_generate",
        "task_type": "GenerateTask",
        "dataset_save_path": "../files/datasets/<slug>_generate.json",
        "is_save_dataset": true,
        "eval_type": ["execute_accuracy"],
        "meta": {
          "task": {
            "generate_type": "<GeneratorClass>"
          }
        }
      }
    ],
    "cpx_task_meta": [
      {
        "task_id": "<slug>_full",
        "task_lis": ["<slug>_reduce", "<slug>_generate"],
        "eval_type": ["execute_accuracy"],
        "dataset_save_path": "../files/datasets/<slug>_full.json",
        "is_save_dataset": true
      }
    ]
  },
  "engine": {
    "exec_process": ["<slug>_full"]
  },
  "generate_num": 1
}
