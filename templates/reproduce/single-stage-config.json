{
  "api_key": {
    "<provider>": "${ENV:<PROVIDER>_API_KEY}"
  },
  "llm": {
    "use": "<provider>",
    "model_name": "<model>",
    "context_window": 8192,
    "temperature": 0,
    "time_out": 60
  },
  "dataset": {
    "data_source": "<benchmark>:<split>:",
    "need_few_shot": false,
    "need_external": false
  },
  "database": {
    "schema_source": "<benchmark>:<split>:",
    "need_build_index": false
  },
  "task": {
    "task_meta": [
      {
        "task_id": "generate",
        "task_type": "GenerateTask",
        "dataset_save_path": "../files/datasets/<benchmark>_<method>_generate.json",
        "is_save_dataset": true,
        "eval_type": ["execute_accuracy"],
        "meta": {
          "task": {
            "generate_type": "<ClassName>"
          }
        }
      }
    ],
    "cpx_task_meta": []
  },
  "engine": {
    "exec_process": ["generate"]
  },
  "generate_num": 1
}
